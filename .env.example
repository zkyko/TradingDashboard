DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
RESEND_API_KEY=
REVIEW_EMAIL_TO=
REVIEW_EMAIL_FROM=Zkyko <review@example.com>
# Optional overrides. By default the app uses its installed mcp-remote bridge
# with https://agent.robinhood.com/mcp/trading and OAuth.
ROBINHOOD_MCP_COMMAND=
ROBINHOOD_MCP_ARGS=
SYNC_SECRET=change-me

# Session signing for Auth.js. Generate with: npx auth secret
# Users register with email/password in the app (stored in SQLite).
AUTH_SECRET=
# Default: 12 hours. Increase only if you accept longer-lived sessions.
AUTH_SESSION_MAX_AGE=43200
